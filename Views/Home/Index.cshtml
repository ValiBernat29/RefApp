@{
    ViewData["Title"] = "Home";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Referee Portal | Secure Login</title>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <main class="page">
        <div class="page-header">
            <div>
                <div class="page-eyebrow">Referee Portal</div>
                <h1 class="page-title">Secure <em>Login</em></h1>
            </div>
        </div>
        <div class="panel" style="max-width:620px;">
            <div class="panel-body">
                <p class="muted" style="margin-bottom:14px;">Please enter your credentials to access the dashboard.</p>
                <form asp-area="Identity" asp-page="/Account/Login" asp-route-returnUrl="@Url.Action("Index", "Home")" method="post" class="form-grid">
                        @Html.AntiForgeryToken()
                        <div>
                            <label>Email Address</label>
                            <input name="Input.Email" autocomplete="username" placeholder="referee@league.com" type="email" />
                        </div>
                        <div>
                            <label>Password</label>
                            <input name="Input.Password" autocomplete="current-password" placeholder="********" type="password" />
                        </div>
                        <div>
                            <label>
                                <input name="Input.RememberMe" value="true" id="remember" type="checkbox" style="width:auto;margin-right:8px;" />
                                Remember this device for 30 days
                            </label>
                        </div>
                        <div class="actions">
                            <button class="btn btn-primary" type="submit">Sign In</button>
                            <a class="btn btn-secondary" asp-area="Identity" asp-page="/Account/ForgotPassword">Forgot Password?</a>
                        </div>
                </form>
                <div style="margin-top:16px;">
                    <p class="muted">
                        New official? <a href="#">Request Access</a>
                    </p>
                    </div>
            </div>
        </div>
    </main>
</body>
</html>