@model RefApp.Models.Unavailability
@{
    ViewData["Title"] = "Add Unavailability";
}

<main class="page">
    <h1 class="section-title">Add Unavailability</h1>
    <form asp-action="CreateUnavailability" method="post" class="form-card form-grid">
        <div asp-validation-summary="All" class="validation"></div>

        <div>
            <label asp-for="StartDate"></label>
            <input asp-for="StartDate" type="date" />
            <span asp-validation-for="StartDate" class="validation"></span>
        </div>

        <div>
            <label asp-for="EndDate"></label>
            <input asp-for="EndDate" type="date" />
            <span asp-validation-for="EndDate" class="validation"></span>
        </div>

        <div>
            <label asp-for="Reason">Reason (optional)</label>
            <input asp-for="Reason" placeholder="e.g. Vacation, injury" />
        </div>

        <div class="actions">
            <button type="submit" class="btn btn-primary">Add</button>
            <a asp-action="MyAvailability" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
