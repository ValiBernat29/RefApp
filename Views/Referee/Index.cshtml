@{
    ViewData["Title"] = "Referee Dashboard";
}

<main class="page">
    <div class="page-header">
        <div>
            <div class="page-eyebrow">Dashboard · Referee</div>
            <h1 class="page-title">My <em>Workspace</em></h1>
        </div>
    </div>
    <div class="content-grid">
        <div>
            <div class="panel">
                <div class="panel-header"><span class="panel-title">Quick Access</span></div>
                <div class="panel-body actions">
                    <a asp-controller="Referee" asp-action="MyMatches" class="btn btn-primary">My Matches</a>
                    <a asp-controller="Referee" asp-action="MyAvailability" class="btn btn-secondary">My Availability</a>
                </div>
            </div>
            <p class="muted">Tip: keep your unavailability up to date so the board can assign you to the right matches.</p>
        </div>
    </div>
</main>
