@{
    ViewData["Title"] = "Referee Dashboard";
}

<main class="flex-1 pb-24 p-4">
    <h1 class="text-2xl font-bold tracking-tight mb-6">Welcome</h1>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
        <a asp-controller="Referee" asp-action="MyMatches"
           class="flex flex-col gap-2 rounded-xl p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm hover:bg-slate-50 dark:hover:bg-slate-800/60 transition-colors">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-primary">sports_soccer</span>
                <h2 class="text-lg font-semibold">My Matches</h2>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400">
                See your upcoming and past matches.
            </p>
        </a>

        <a asp-controller="Referee" asp-action="MyAvailability"
           class="flex flex-col gap-2 rounded-xl p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm hover:bg-slate-50 dark:hover:bg-slate-800/60 transition-colors">
            <div class="flex items-center gap-2">
                <span class="material-symbols-outlined text-amber-500">event_busy</span>
                <h2 class="text-lg font-semibold">My Unavailability</h2>
            </div>
            <p class="text-sm text-slate-600 dark:text-slate-400">
                Block dates when you cannot referee.
            </p>
        </a>
    </div>

    <p class="text-xs text-slate-500 dark:text-slate-400">
        Tip: keep your unavailability up to date so the board can assign you to the right matches.
    </p>
</main>
