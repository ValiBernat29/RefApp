@model IEnumerable<RefApp.Models.Unavailability>
@{
    ViewData["Title"] = "My Availability";
}

<main class="page">
    <h1 class="section-title">My Availability</h1>
    <div class="toolbar"><div></div><a asp-action="CreateUnavailability" class="btn btn-primary">Add Unavailability</a></div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="panel">
        @if (!Model.Any())
        {
            <div class="panel-body"><p class="muted">No blocked dates. <a asp-action="CreateUnavailability">Add unavailability</a>.</p></div>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Start</th>
                            <th>End</th>
                            <th>Reason</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            <tr>
                                <td>@u.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@u.EndDate.ToString("yyyy-MM-dd")</td>
                                <td>@(u.Reason ?? "—")</td>
                                <td class="actions">
                                    <a asp-action="EditUnavailability" asp-route-id="@u.Id" class="btn btn-sm btn-secondary">Edit</a>
                                    <a asp-action="DeleteUnavailability" asp-route-id="@u.Id" class="btn btn-sm btn-danger">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</main>
