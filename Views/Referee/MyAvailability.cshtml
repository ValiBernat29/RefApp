@model IEnumerable<RefApp.Models.Unavailability>
@{
    ViewData["Title"] = "My Availability";
}

<main class="flex-1 p-4 pb-24">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <h1 class="text-2xl font-bold tracking-tight">My Availability</h1>
        <a asp-action="CreateUnavailability" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white font-semibold py-2.5 px-4 rounded-lg transition-colors">
            <span class="material-symbols-outlined text-lg">add</span>
            Add Unavailability
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 p-4 rounded-lg bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-200 border border-green-200 dark:border-green-800">
            @TempData["Success"]
        </div>
    }

    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden shadow-sm">
        @if (!Model.Any())
        {
            <div class="p-8 text-center text-slate-500 dark:text-slate-400">
                <span class="material-symbols-outlined text-4xl mb-2 block">event_available</span>
                <p>No blocked dates. <a asp-action="CreateUnavailability" class="text-primary dark:text-slate-300 font-medium hover:underline">Add unavailability</a>.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700">
                        <tr>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Start</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">End</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Reason</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        @foreach (var u in Model)
                        {
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30">
                                <td class="px-4 py-3 text-sm">@u.StartDate.ToString("yyyy-MM-dd")</td>
                                <td class="px-4 py-3 text-sm">@u.EndDate.ToString("yyyy-MM-dd")</td>
                                <td class="px-4 py-3 text-sm text-slate-600 dark:text-slate-400">@(u.Reason ?? "—")</td>
                                <td class="px-4 py-3">
                                    <a asp-action="EditUnavailability" asp-route-id="@u.Id" class="text-primary dark:text-slate-300 font-medium hover:underline text-sm mr-3">Edit</a>
                                    <a asp-action="DeleteUnavailability" asp-route-id="@u.Id" class="text-red-600 dark:text-red-400 font-medium hover:underline text-sm">Delete</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</main>
