@model RefApp.Models.Unavailability
@{
    ViewData["Title"] = "Delete Unavailability";
}

<main class="max-w-[1440px] mx-auto p-8 space-y-6">

    <div>
        <h1 class="text-2xl font-bold text-gray-900">Delete Unavailability</h1>
        <nav class="text-sm text-gray-400 mt-0.5">
            <a asp-controller="Referee" asp-action="Index" class="hover:text-gray-600">Dashboard</a>
            <span class="mx-1">•</span>
            <a asp-controller="Referee" asp-action="MyAvailability" class="hover:text-gray-600">My Availability</a>
            <span class="mx-1">•</span><span>Delete</span>
        </nav>
    </div>

    <section class="bg-white rounded-xl card-shadow p-6 max-w-xl">
        <div class="flex items-start space-x-4 mb-6">
            <div class="p-3 rounded-full bg-red-50 flex-shrink-0">
                <svg class="h-6 w-6 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                </svg>
            </div>
            <div>
                <h2 class="font-semibold text-gray-800 mb-1">Are you sure?</h2>
                <p class="text-sm text-gray-500">This will permanently remove this blocked period.</p>
            </div>
        </div>

        <dl class="grid grid-cols-2 gap-x-4 gap-y-3 mb-6 text-sm border border-gray-100 rounded-lg p-4 bg-gray-50">
            <dt class="text-gray-500 font-medium">Start</dt>
            <dd class="text-gray-800">@Model.StartDate.ToString("yyyy-MM-dd")</dd>
            <dt class="text-gray-500 font-medium">End</dt>
            <dd class="text-gray-800">@Model.EndDate.ToString("yyyy-MM-dd")</dd>
            @if (!string.IsNullOrEmpty(Model.Reason))
            {
                <dt class="text-gray-500 font-medium">Reason</dt>
                <dd class="text-gray-800">@Model.Reason</dd>
            }
        </dl>

        <form asp-action="DeleteUnavailability" asp-route-id="@Model.Id" method="post"
              class="flex items-center gap-3">
            <button type="submit"
                    class="bg-red-500 hover:bg-red-600 text-white px-6 py-2.5 rounded-lg text-sm font-medium transition-colors">Delete</button>
            <a asp-action="MyAvailability"
               class="action-btn-outline px-6 py-2.5 rounded-lg text-sm font-medium">Cancel</a>
        </form>
    </section>

</main>
