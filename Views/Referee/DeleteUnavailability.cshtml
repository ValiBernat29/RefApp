@model RefApp.Models.Unavailability
@{
    ViewData["Title"] = "Delete Unavailability";
}

<main class="page">
    <h1 class="section-title">Delete Unavailability</h1>
    <div class="form-card">
        <p class="muted" style="margin-bottom:12px;">Are you sure you want to remove this blocked period?</p>
        <dl style="display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-bottom:16px;">
            <dt class="muted">Start</dt>
            <dd>@Model.StartDate.ToString("yyyy-MM-dd")</dd>
            <dt class="muted">End</dt>
            <dd>@Model.EndDate.ToString("yyyy-MM-dd")</dd>
            @if (!string.IsNullOrEmpty(Model.Reason))
            {
                <dt class="muted">Reason</dt>
                <dd>@Model.Reason</dd>
            }
        </dl>
        <form asp-action="DeleteUnavailability" asp-route-id="@Model.Id" method="post" class="actions">
            <button type="submit" class="btn btn-danger">Delete</button>
            <a asp-action="MyAvailability" class="btn btn-secondary">Cancel</a>
        </form>
    </div>
</main>
