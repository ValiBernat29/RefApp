@model RefApp.Models.Unavailability
@{
    ViewData["Title"] = "Delete Unavailability";
}

<main class="flex-1 p-4 pb-24 max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold tracking-tight mb-6">Delete Unavailability</h1>

    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm">
        <p class="text-slate-600 dark:text-slate-400 mb-4">Are you sure you want to remove this blocked period?</p>
        <dl class="grid grid-cols-2 gap-2 text-sm mb-6">
            <dt class="text-slate-500 dark:text-slate-400">Start</dt>
            <dd>@Model.StartDate.ToString("yyyy-MM-dd")</dd>
            <dt class="text-slate-500 dark:text-slate-400">End</dt>
            <dd>@Model.EndDate.ToString("yyyy-MM-dd")</dd>
            @if (!string.IsNullOrEmpty(Model.Reason))
            {
                <dt class="text-slate-500 dark:text-slate-400">Reason</dt>
                <dd>@Model.Reason</dd>
            }
        </dl>
        <form asp-action="DeleteUnavailability" asp-route-id="@Model.Id" method="post" class="flex gap-3">
            <button type="submit" class="bg-red-600 hover:bg-red-700 text-white font-semibold py-2.5 px-6 rounded-lg transition-colors">
                Delete
            </button>
            <a asp-action="MyAvailability" class="inline-flex items-center justify-center py-2.5 px-6 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-700 dark:text-slate-300 font-medium hover:bg-slate-50 dark:hover:bg-slate-800">
                Cancel
            </a>
        </form>
    </div>
</main>
