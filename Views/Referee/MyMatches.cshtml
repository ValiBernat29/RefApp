@model IEnumerable<RefApp.Models.Match>

@{
    ViewData["Title"] = "My Matches";
}

<main class="page">
    <h1 class="section-title">My Matches</h1>
    <p class="muted">View your upcoming and past assignments, and see your referee team.</p>
    <div class="panel">
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date & Time</th>
                        <th>Match</th>
                        <th>Location</th>
                        <th>Referee Team</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4">
                                You have no match assignments yet.
                            </td>
                        </tr>
                    }
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>@m.MatchDate.ToString("dd MMM yyyy HH:mm")</td>
                            <td>
                                <span>@m.HomeTeam</span> vs <span>@m.AwayTeam</span>
                            </td>
                            <td>@m.Location</td>
                            
                            <td>
                                <div>
                                    @foreach (var assignment in m.Assignments.OrderBy(a => a.RoleType))
                                    {
                                        var refName = assignment.Referee?.DisplayName ?? assignment.Referee?.UserName ?? "Unknown";
                                        <div style="margin-bottom:4px;">
                                            <span class="badge b-sky">@assignment.RoleType</span>
                                            <span>@refName</span>
                                        </div>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</main>