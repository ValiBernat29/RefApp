<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - RefApp</title>
    <link href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Outfit:wght@300;400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    @{
        var controller = (ViewContext.RouteData.Values["controller"]?.ToString() ?? "").ToLowerInvariant();
        var action = (ViewContext.RouteData.Values["action"]?.ToString() ?? "").ToLowerInvariant();
    }
    <nav class="top-nav">
        <a asp-controller="Home" asp-action="Index" class="nav-brand">
            <span class="brand-dot"></span>
            Referee Portal
        </a>
        <ul class="nav-links">
            @if (User.IsInRole("Board"))
            {
                <li><a asp-controller="Board" asp-action="Index" class="@(controller == "board" && action == "index" ? "active" : "")">Home</a></li>
                <li><a asp-controller="Board" asp-action="UpcomingMatches" class="@(controller == "board" && (action == "upcomingmatches" || action == "assign") ? "active" : "")">Upcoming Matches</a></li>
                <li><a asp-controller="Board" asp-action="UnavailabilityRoster" class="@(controller == "board" && action == "unavailabilityroster" ? "active" : "")">Unavailability Roster</a></li>
                <li><a asp-controller="Board" asp-action="Users" class="@(controller == "board" && action == "users" ? "active" : "")">Users</a></li>
                <li><a asp-controller="Board" asp-action="Teams" class="@(controller == "board" && action == "teams" ? "active" : "")">Teams</a></li>
            }
            else if (User.IsInRole("Referee"))
            {
                <li><a asp-controller="Referee" asp-action="Index" class="@(controller == "referee" && action == "index" ? "active" : "")">Dashboard</a></li>
                <li><a asp-controller="Referee" asp-action="MyMatches" class="@(controller == "referee" && action == "mymatches" ? "active" : "")">My Matches</a></li>
                <li><a asp-controller="Referee" asp-action="MyAvailability" class="@(controller == "referee" && action == "myavailability" ? "active" : "")">My Availability</a></li>
            }
            else
            {
                <li><a asp-controller="Home" asp-action="Index" class="@(controller == "home" ? "active" : "")">Home</a></li>
            }
        </ul>
        <div class="nav-right">
            <partial name="_LoginPartial" />
        </div>
    </nav>
    @RenderBody()
    @RenderSection("Scripts", required: false)
</body>
</html>