@using Microsoft.AspNetCore.Identity
@using RefApp.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<ul class="navbar-nav">
@if (SignInManager.IsSignedIn(User))
{
    <li class="nav-item">
        <a class="nav-link text-slate-600 dark:text-slate-300" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
            @(UserManager.GetUserAsync(User).Result?.DisplayName ?? User.Identity?.Name ?? "Account")
        </a>
    </li>
    <li class="nav-item">
        <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })" method="post">
            <button type="submit" class="nav-link btn btn-link text-slate-600 dark:text-slate-300 border-0">Logout</button>
        </form>
    </li>
}
else
{
    <li class="nav-item">
        <a class="nav-link text-slate-600 dark:text-slate-300" asp-area="Identity" asp-page="/Account/Login">Login</a>
    </li>
}
</ul>
