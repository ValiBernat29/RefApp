@model RefApp.ViewModels.CreateMatchViewModel
@{
    ViewData["Title"] = "Edit Match";
}

<main class="flex-1 p-4 pb-24 max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold tracking-tight mb-6">Edit Match</h1>

    <form asp-action="EditMatch" method="post" class="space-y-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="ModelOnly" class="text-red-600 dark:text-red-400 text-sm"></div>

        <div>
            <label asp-for="League" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <select asp-for="League"
                    asp-items="Html.GetEnumSelectList<RefApp.Models.League>()"
                    class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent"
                    id="leagueSelect">
                <option value="">Select league</option>
            </select>
            <span asp-validation-for="League" class="text-red-600 dark:text-red-400 text-xs"></span>
        </div>

        <div>
            <label asp-for="MatchDate" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <input asp-for="MatchDate" type="datetime-local" class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent" />
            <span asp-validation-for="MatchDate" class="text-red-600 dark:text-red-400 text-xs"></span>
        </div>

        <div>
            <label asp-for="Location" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <input asp-for="Location" class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent" />
            <span asp-validation-for="Location" class="text-red-600 dark:text-red-400 text-xs"></span>
        </div>

        <div>
            <label asp-for="HomeTeamId" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <select asp-for="HomeTeamId"
                    class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent">
                <option value="">Select home team</option>
                @if (Model.Teams != null)
                {
                    foreach (var t in Model.Teams.OrderBy(t => t.Name))
                    {
                        <option value="@t.Id" data-league="@((int)t.League)">@t.Name</option>
                    }
                }
            </select>
            <span asp-validation-for="HomeTeamId" class="text-red-600 dark:text-red-400 text-xs"></span>
        </div>

        <div>
            <label asp-for="AwayTeamId" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <select asp-for="AwayTeamId"
                    class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent">
                <option value="">Select away team</option>
                @if (Model.Teams != null)
                {
                    foreach (var t in Model.Teams.OrderBy(t => t.Name))
                    {
                        <option value="@t.Id" data-league="@((int)t.League)">@t.Name</option>
                    }
                }
            </select>
            <span asp-validation-for="AwayTeamId" class="text-red-600 dark:text-red-400 text-xs"></span>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-primary hover:bg-primary/90 text-white font-semibold py-2.5 px-6 rounded-lg transition-colors">
                Save Changes
            </button>
            <a asp-action="UpcomingMatches" class="inline-flex items-center justify-center py-2.5 px-6 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-700 dark:text-slate-300 font-medium hover:bg-slate-50 dark:hover:bg-slate-800">
                Cancel
            </a>
        </div>
    </form>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const leagueSelect = document.getElementById('leagueSelect');
            const homeSelect = document.getElementById('@Html.IdFor(m => m.HomeTeamId)');
            const awaySelect = document.getElementById('@Html.IdFor(m => m.AwayTeamId)');

            function filterTeams() {
                const league = leagueSelect.value;
                [homeSelect, awaySelect].forEach(select => {
                    if (!select) return;
                    Array.from(select.options).forEach(opt => {
                        if (!opt.value) return; // keep placeholder
                        const optLeague = opt.getAttribute('data-league');
                        opt.hidden = league && optLeague !== league;
                    });
                });
            }

            if (leagueSelect) {
                leagueSelect.addEventListener('change', filterTeams);
                filterTeams();
            }
        })();
    </script>
}

