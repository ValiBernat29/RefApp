@{
    ViewData["Title"] = "Board Dashboard";
}

<main class="max-w-[1440px] mx-auto p-8 grid grid-cols-12 gap-8">

    <!-- Left Column -->
    <div class="col-span-12 lg:col-span-9 space-y-8">

        <!-- Page heading -->
        <div>
            <h1 class="text-2xl font-bold text-gray-900 leading-tight">Match Overview</h1>
            <nav class="text-sm text-gray-400 mt-0.5">
                <span>Dashboard</span>
                <span class="mx-1">•</span>
                <span>Board</span>
            </nav>
        </div>

        <!-- Summary Cards -->
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div class="summary-card-blue rounded-xl p-6 text-white flex justify-between items-start card-shadow">
                <div>
                    <div class="text-6xl font-extrabold mb-1">@(ViewBag.UpcomingMatchesCount ?? 0)</div>
                    <div class="text-blue-50 font-medium">Upcoming matches this week</div>
                </div>
                <div class="bg-white/20 p-2 rounded-full">
                    <svg class="h-10 w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                    </svg>
                </div>
            </div>
            <div class="summary-card-blue rounded-xl p-6 text-white flex justify-between items-start card-shadow">
                <div>
                    <div class="text-6xl font-extrabold mb-1">@(ViewBag.MatchesNeedingAssignments ?? 0)</div>
                    <div class="text-blue-50 font-medium">Matches needing referees</div>
                </div>
                <div class="bg-white/20 p-2 rounded-full">
                    <svg class="h-10 w-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                    </svg>
                </div>
            </div>
        </div>

        <!-- Pending Assignments -->
        <section class="bg-white rounded-xl card-shadow overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between">
                <h2 class="text-xl font-bold text-gray-800">Pending Assignments</h2>
                <a asp-controller="Board" asp-action="UpcomingMatches"
                   class="text-sm font-medium text-sky-600 hover:text-sky-700 transition-colors">View All →</a>
            </div>
            <div class="overflow-x-auto">
                @{
                    var upcoming = ViewBag.UpcomingMatches as IEnumerable<RefApp.Models.Match> ?? Enumerable.Empty<RefApp.Models.Match>();
                }
                @if (upcoming.Any())
                {
                    <table class="w-full text-left" id="pending-matches-table">
                        <thead>
                            <tr class="bg-gray-50 text-gray-500 text-xs font-medium uppercase tracking-wider">
                                <th class="px-6 py-3">Match</th>
                                <th class="px-6 py-3">Date &amp; Time</th>
                                <th class="px-6 py-3">Venue</th>
                                <th class="px-6 py-3">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-gray-100">
                            @foreach (var m in upcoming.Take(5))
                            {
                                <tr class="text-gray-700 hover:bg-gray-50/50 transition-colors">
                                    <td class="px-6 py-4 font-medium">@m.HomeTeam vs @m.AwayTeam</td>
                                    <td class="px-6 py-4">@m.MatchDate.ToString("ddd, MMM d, yyyy · HH:mm")</td>
                                    <td class="px-6 py-4">@m.Location</td>
                                    <td class="px-6 py-4">
                                        <a asp-controller="Board" asp-action="Assign" asp-route-id="@m.Id"
                                           class="btn-assign text-white px-6 py-1.5 rounded-lg text-sm font-medium inline-block">Assign</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
                else
                {
                    <div class="px-6 py-10 text-center text-gray-400 text-sm">
                        No upcoming matches.
                        <a asp-controller="Board" asp-action="CreateMatch" class="text-sky-600 hover:underline ml-1">Create one</a>.
                    </div>
                }
            </div>
        </section>

        <!-- Unavailability Roster -->
        <section class="bg-white rounded-xl card-shadow overflow-hidden">
            <div class="px-6 py-5 border-b border-gray-100 flex items-center justify-between">
                <h2 class="text-xl font-bold text-gray-800">Unavailability Roster</h2>
                <a asp-controller="Board" asp-action="UnavailabilityRoster"
                   class="text-sm font-medium text-sky-600 hover:text-sky-700 transition-colors">View All →</a>
            </div>
            <div class="p-6 space-y-1">
                @{
                    var recentUnavail = ViewBag.RecentUnavailabilities as IEnumerable<RefApp.Models.Unavailability> ?? Enumerable.Empty<RefApp.Models.Unavailability>();
                }
                @if (recentUnavail.Any())
                {
                    @foreach (var u in recentUnavail)
                    {
                        var name = u.Referee?.DisplayName ?? u.Referee?.Email ?? u.Referee?.UserName ?? "—";
                        <div class="flex items-center justify-between py-3 border-b border-gray-50 last:border-0">
                            <span class="font-medium text-gray-700 w-1/3">@name</span>
                            <div class="flex items-center text-gray-500 w-1/3 text-sm">
                                <svg class="h-4 w-4 mr-2 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"/>
                                </svg>
                                <span>@u.StartDate.ToString("MMM d") – @u.EndDate.ToString("MMM d, yyyy")</span>
                            </div>
                            <div class="w-1/3 flex justify-end">
                                <span class="btn-unavailable text-white px-4 py-1.5 rounded-lg text-sm font-medium inline-flex items-center space-x-2">
                                    <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path d="M18.364 18.364A9 9 0 005.636 5.636m12.728 12.728A9 9 0 015.636 5.636m12.728 12.728L5.636 5.636" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                                    </svg>
                                    <span>Unavailable</span>
                                </span>
                            </div>
                        </div>
                    }
                }
                else
                {
                    <p class="text-gray-400 text-sm py-4 text-center">No current unavailability records.</p>
                }
            </div>
        </section>

    </div>

    <!-- Sidebar -->
    <aside class="col-span-12 lg:col-span-3">
        <section class="bg-white rounded-xl card-shadow p-6">
            <h2 class="text-xl font-bold text-gray-800 mb-6">Quick Actions</h2>
            <div class="flex flex-col space-y-4">
                <a asp-action="CreateMatch"
                   class="action-btn-outline w-full py-4 px-4 rounded-xl flex items-center space-x-4 text-left group">
                    <div class="p-1 rounded-md bg-gray-50 group-hover:bg-white border border-gray-100">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M12 6v6m0 0v6m0-6h6m-6 0H6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                        </svg>
                    </div>
                    <span class="font-medium text-gray-600">Create Match</span>
                </a>

                <a asp-action="Users"
                   class="action-btn-outline w-full py-4 px-4 rounded-xl flex items-center space-x-4 text-left group">
                    <div class="p-1 rounded-md bg-gray-50 group-hover:bg-white border border-gray-100">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                        </svg>
                    </div>
                    <span class="font-medium text-gray-600">Manage Users</span>
                </a>

                <a asp-action="Teams"
                   class="action-btn-outline w-full py-4 px-4 rounded-xl flex items-center space-x-4 text-left group">
                    <div class="p-1 rounded-md bg-gray-50 group-hover:bg-white border border-gray-100">
                        <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
                        </svg>
                    </div>
                    <span class="font-medium text-gray-600">Manage Teams</span>
                </a>
            </div>
        </section>
    </aside>

</main>
