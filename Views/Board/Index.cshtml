@{
    ViewData["Title"] = "Board Dashboard";
}

<main class="page">
    <div class="page-header">
        <div>
            <div class="page-eyebrow">Dashboard · Board</div>
            <h1 class="page-title">Match <em>Overview</em></h1>
        </div>
    </div>

    <div class="stats-row">
        <div class="stat-tile amber">
            <div class="stat-num">@(ViewBag.PendingMatches ?? 0)</div>
            <div class="stat-label">Matches awaiting assignment</div>
        </div>
        <div class="stat-tile emerald">
            <div class="stat-num">@(ViewBag.MatchesNeedingAssignments ?? 0)</div>
            <div class="stat-label">Matches needing referees</div>
        </div>
    </div>

    <div class="content-grid">
        <div>
            <div class="panel">
                <div class="panel-header">
                    <span class="panel-title">Pending Assignments</span>
                    <a asp-controller="Board" asp-action="UpcomingMatches" class="btn btn-sm btn-secondary">View All</a>
                </div>
                <div class="panel-body">
                    @{
                        var upcoming = ViewBag.UpcomingMatches as IEnumerable<RefApp.Models.Match> ?? Enumerable.Empty<RefApp.Models.Match>();
                    }
                    @if (upcoming.Any())
                    {
                        <div class="table-wrap">
                            <table class="data-table">
                                <thead>
                                    <tr><th>Match</th><th>Date</th><th>Venue</th><th></th></tr>
                                </thead>
                                <tbody>
                                @foreach (var m in upcoming.Take(5))
                                {
                                    <tr>
                                        <td>@m.HomeTeam vs @m.AwayTeam</td>
                                        <td>@m.MatchDate.ToString("dd MMM yyyy HH:mm")</td>
                                        <td>@m.Location</td>
                                        <td><a asp-controller="Board" asp-action="Assign" asp-route-id="@m.Id" class="btn btn-sm btn-primary">Assign</a></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="muted">No upcoming matches. <a asp-controller="Board" asp-action="CreateMatch">Create one</a>.</p>
                    }
                </div>
            </div>

            <div class="panel">
                <div class="panel-header">
                    <span class="panel-title">Unavailability Roster</span>
                    <a asp-controller="Board" asp-action="UnavailabilityRoster" class="btn btn-sm btn-secondary">View All</a>
                </div>
                <div class="panel-body">
                    @{
                        var recentUnavail = ViewBag.RecentUnavailabilities as IEnumerable<RefApp.Models.Unavailability> ?? Enumerable.Empty<RefApp.Models.Unavailability>();
                    }
                    @if (recentUnavail.Any())
                    {
                        <div class="table-wrap">
                            <table class="data-table">
                                <thead><tr><th>Referee</th><th>Range</th><th>Status</th></tr></thead>
                                <tbody>
                                @foreach (var u in recentUnavail)
                                {
                                    var name = u.Referee?.DisplayName ?? u.Referee?.Email ?? u.Referee?.UserName ?? "—";
                                    <tr>
                                        <td>@name</td>
                                        <td>@u.StartDate.ToString("MMM d") - @u.EndDate.ToString("MMM d, yyyy")</td>
                                        <td><span class="badge b-rose">Unavailable</span></td>
                                    </tr>
                                }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <p class="muted">No current unavailability records.</p>
                    }
                </div>
            </div>
        </div>

        <aside class="side-col">
            <div class="panel">
                <div class="panel-header"><span class="panel-title">Quick Actions</span></div>
                <div class="panel-body actions">
                    <a asp-action="CreateMatch" class="btn btn-primary">Create Match</a>
                    <a asp-action="Users" class="btn btn-secondary">Manage Users</a>
                    <a asp-action="Teams" class="btn btn-secondary">Manage Teams</a>
                </div>
            </div>
        </aside>
    </div>
</main>
