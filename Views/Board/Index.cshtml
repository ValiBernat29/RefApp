@{
    ViewData["Title"] = "Board Dashboard";
}

<main class="flex-1 pb-24">
    <!-- Stats Overview -->
    <div class="grid grid-cols-2 lg:grid-cols-3 gap-3 p-4">
        <div class="flex flex-col gap-1 rounded-xl p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm">
            <span class="material-symbols-outlined text-primary dark:text-slate-400 text-xl">pending_actions</span>
            <p class="text-slate-500 dark:text-slate-400 text-xs font-medium mt-1">Pending Matches</p>
            <p class="text-2xl font-bold">@(ViewBag.PendingMatches ?? 0)</p>
        </div>
        <div class="flex flex-col gap-1 rounded-xl p-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 shadow-sm">
            <span class="material-symbols-outlined text-amber-500 text-xl">event_busy</span>
            <p class="text-slate-500 dark:text-slate-400 text-xs font-medium mt-1">Unavailable Refs</p>
            <p class="text-2xl font-bold">@(ViewBag.UnavailableRefsCount ?? 0)</p>
        </div>
        <div class="col-span-2 lg:col-span-1 flex flex-col gap-1 rounded-xl p-4 bg-primary text-white shadow-md">
            <span class="material-symbols-outlined text-xl">assignment_late</span>
            <p class="text-slate-300 text-xs font-medium mt-1">Open Requests</p>
            <p class="text-2xl font-bold">5</p>
        </div>
    </div>
    <!-- Tab Navigation -->
    <div class="px-4 mb-2">
        <div class="flex border-b border-slate-200 dark:border-slate-800 gap-6">
            <a class="flex flex-col items-center justify-center border-b-2 border-primary dark:border-slate-100 pb-3" asp-controller="Board" asp-action="UpcomingMatches">
                <p class="text-primary dark:text-slate-100 text-sm font-bold">Matches</p>
            </a>
            <a class="flex flex-col items-center justify-center border-b-2 border-transparent text-slate-500 dark:text-slate-400 pb-3" asp-controller="Board" asp-action="UnavailabilityRoster">
                <p class="text-sm font-medium">Unavailability</p>
            </a>
        </div>
    </div>
    <!-- Pending Assignments Section -->
    <section class="mt-6 px-4">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold tracking-tight">Pending Assignments</h2>
            <a asp-controller="Board" asp-action="UpcomingMatches" class="text-xs font-semibold text-primary dark:text-slate-400 hover:underline">View all</a>
        </div>
        <div class="space-y-3">
            @{
                var upcoming = ViewBag.UpcomingMatches as IEnumerable<RefApp.Models.Match> ?? Enumerable.Empty<RefApp.Models.Match>();
            }
            @if (upcoming.Any())
            {
                foreach (var m in upcoming.Take(3))
                {
                    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-4 shadow-sm">
                        <div class="flex justify-between items-start mb-3">
                            <div>
                                <h3 class="text-base font-bold mt-1">@m.HomeTeam vs @m.AwayTeam</h3>
                            </div>
                            <div class="text-right">
                                <p class="text-sm font-bold">@m.MatchDate.ToString("ddd, MMM d")</p>
                                <p class="text-xs text-slate-500">@m.MatchDate.ToString("HH:mm") • @m.Location</p>
                            </div>
                        </div>
                        <a asp-controller="Board" asp-action="Assign" asp-route-id="@m.Id" class="block w-full bg-primary dark:bg-slate-100 text-white dark:text-primary py-2.5 rounded-lg font-bold text-sm flex items-center justify-center gap-2 text-center">
                            <span class="material-symbols-outlined text-base">person_add</span>
                            Assign Referees
                        </a>
                    </div>
                }
            }
            else
            {
                <p class="text-slate-500 dark:text-slate-400 text-sm">No upcoming matches. <a asp-controller="Board" asp-action="CreateMatch" class="text-primary dark:text-slate-300 font-medium hover:underline">Create one</a>.</p>
            }
        </div>
    </section>
    <!-- Unavailability Roster -->
    <section class="mt-8 px-4">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-xl font-bold tracking-tight">Unavailability Roster</h2>
            <a class="text-primary dark:text-slate-400 text-xs font-bold flex items-center gap-1" asp-controller="Board" asp-action="UnavailabilityRoster">
                View All <span class="material-symbols-outlined text-sm">chevron_right</span>
            </a>
        </div>
        <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl divide-y divide-slate-100 dark:divide-slate-800">
            @{
                var recentUnavail = ViewBag.RecentUnavailabilities as IEnumerable<RefApp.Models.Unavailability> ?? Enumerable.Empty<RefApp.Models.Unavailability>();
            }
            @if (recentUnavail.Any())
            {
                foreach (var u in recentUnavail)
                {
                    var name = u.Referee?.DisplayName ?? u.Referee?.Email ?? u.Referee?.UserName ?? "—";
                    <div class="p-4 flex items-center justify-between">
                        <div>
                            <p class="text-sm font-bold">@name</p>
                            <p class="text-[10px] text-slate-500">@u.StartDate.ToString("MMM d") – @u.EndDate.ToString("MMM d, yyyy")</p>
                        </div>
                        <div class="text-right">
                            <span class="text-[10px] font-bold text-red-500 bg-red-500/10 px-2 py-0.5 rounded-full">Unavailable</span>
                            @if (!string.IsNullOrEmpty(u.Reason))
                            {
                                <p class="text-[10px] text-slate-400 mt-1">@u.Reason</p>
                            }
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="p-4 text-slate-500 dark:text-slate-400 text-sm">No current unavailability records.</div>
            }
        </div>
    </section>
</main>
<!-- Bottom Navigation Bar -->
<nav class="fixed bottom-0 left-0 right-0 border-t border-slate-200 dark:border-slate-800 bg-white/95 dark:bg-background-dark/95 backdrop-blur-md px-4 pb-6 pt-2 z-50">
    <div class="flex gap-2">
        <a class="flex flex-1 flex-col items-center justify-center gap-1 text-primary dark:text-slate-100" asp-controller="Board" asp-action="Index">
            <div class="flex h-8 items-center justify-center">
                <span class="material-symbols-outlined fill-1">home</span>
            </div>
            <p class="text-[10px] font-bold leading-normal tracking-wide">Home</p>
        </a>
        <a class="flex flex-1 flex-col items-center justify-center gap-1 text-slate-500 dark:text-slate-400" asp-controller="Board" asp-action="UpcomingMatches">
            <div class="flex h-8 items-center justify-center">
                <span class="material-symbols-outlined">sports_soccer</span>
            </div>
            <p class="text-[10px] font-medium leading-normal tracking-wide">Matches</p>
        </a>
        <a class="flex flex-1 flex-col items-center justify-center gap-1 text-slate-500 dark:text-slate-400" href="#">
            <div class="flex h-8 items-center justify-center">
                <span class="material-symbols-outlined">groups</span>
            </div>
            <p class="text-[10px] font-medium leading-normal tracking-wide">Refs</p>
        </a>
        <a class="flex flex-1 flex-col items-center justify-center gap-1 text-slate-500 dark:text-slate-400" href="#">
            <div class="flex h-8 items-center justify-center">
                <span class="material-symbols-outlined">settings</span>
            </div>
            <p class="text-[10px] font-medium leading-normal tracking-wide">Settings</p>
        </a>
    </div>
</nav>
