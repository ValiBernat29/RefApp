@model IEnumerable<RefApp.Models.Team>
@{
    ViewData["Title"] = "Teams & Leagues";
}

<main class="flex-1 p-4 pb-24">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <h1 class="text-2xl font-bold tracking-tight">Teams &amp; Leagues</h1>
        <a asp-action="CreateTeam" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white font-semibold py-2.5 px-4 rounded-lg transition-colors">
            <span class="material-symbols-outlined text-lg">group_add</span>
            Add Team
        </a>
    </div>

    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden shadow-sm">
        @if (!Model.Any())
        {
            <div class="p-8 text-center text-slate-500 dark:text-slate-400">
                <p>No teams defined yet. Start by adding teams for each league.</p>
            </div>
        }
        else
        {
            <div class="divide-y divide-slate-200 dark:divide-slate-800">
                @foreach (var group in Model.GroupBy(t => t.League).OrderBy(g => g.Key))
                {
                    <section class="p-4">
                        <h2 class="text-sm font-semibold text-slate-600 dark:text-slate-300 mb-3">
                            League @group.Key
                        </h2>
                        <div class="overflow-x-auto">
                            <table class="w-full text-left">
                                <thead class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700">
                                    <tr>
                                        <th class="px-4 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Name</th>
                                        <th class="px-4 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Preferred Day</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                                    @foreach (var t in group.OrderBy(t => t.Name))
                                    {
                                        <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30">
                                            <td class="px-4 py-3 font-medium">@t.Name</td>
                                            <td class="px-4 py-3 text-sm">@t.PreferredMatchDay</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </section>
                }
            </div>
        }
    </div>
</main>

