@model IEnumerable<RefApp.Models.Team>
@{
    ViewData["Title"] = "Teams Management";
}

<main class="page">
    <h1 class="section-title">Teams</h1>
    <div class="toolbar"><div></div><a asp-action="CreateTeam" class="btn btn-primary">Add New Team</a></div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <div class="panel">
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Team Name</th>
                        <th>League</th>
                        <th>Match Day</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var t in Model)
                    {
                        <tr>
                            <td>@t.Name</td>
                            <td>
                                <span class="badge b-sky">@t.League</span>
                            </td>
                            <td>@t.PreferredMatchDay</td>
                            <td class="actions">
                                <a asp-action="EditTeam" asp-route-id="@t.Id" class="btn btn-sm btn-secondary">Edit</a>

                                <form asp-action="DeleteTeam" asp-route-id="@t.Id" method="post" class="inline"
                                    onsubmit="return confirm('Are you sure you want to permanently delete @t.Name?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</main>