@model RefApp.Models.Team
@{
    ViewData["Title"] = "Add Team";
}

<main class="page">
    <h1 class="section-title">Add Team</h1>
    <form asp-action="CreateTeam" method="post" class="form-card form-grid">
        <div asp-validation-summary="ModelOnly" class="validation"></div>

        <div>
            <label asp-for="Name"></label>
            <input asp-for="Name" placeholder="Team name" />
            <span asp-validation-for="Name" class="validation"></span>
        </div>

        <div>
            <label asp-for="League"></label>
            <select asp-for="League" asp-items="Html.GetEnumSelectList<RefApp.Models.League>()"></select>
            <span asp-validation-for="League" class="validation"></span>
        </div>

        <div>
            <label asp-for="PreferredMatchDay"></label>
            <select asp-for="PreferredMatchDay" asp-items="Html.GetEnumSelectList<DayOfWeek>()"></select>
            <p class="muted">
                For example: choose Saturday for L4 teams, Sunday for most other leagues. You can still change individual match dates later.
            </p>
            <span asp-validation-for="PreferredMatchDay" class="validation"></span>
        </div>

        <div class="actions">
            <button type="submit" class="btn btn-primary">Save Team</button>
            <a asp-action="Teams" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

