@model RefApp.ViewModels.EditUserViewModel
@{
    ViewData["Title"] = "Edit Account";
}

<main class="flex-1 p-4 pb-24 max-w-xl mx-auto">
    <h1 class="text-2xl font-bold tracking-tight mb-6">Edit Account</h1>

    <form asp-action="EditUser" method="post"
        class="space-y-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="All" class="text-red-600 dark:text-red-400 text-sm"></div>

        <div>
            <label asp-for="UserName" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <input asp-for="UserName"
                class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent" />
            <span asp-validation-for="UserName" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="DisplayName"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Display Name
                (Optional)</label>
            <input asp-for="DisplayName"
                class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent"
                placeholder="e.g. John Doe" />
            <span asp-validation-for="DisplayName" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Role" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <select asp-for="Role"
                class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent">
                <option value="Referee">Referee</option>
                <option value="Board">Board</option>
            </select>
            <span asp-validation-for="Role" class="text-red-500 text-sm"></span>
        </div>

        <div class="flex gap-3 pt-4">
            <button type="submit"
                class="bg-primary hover:bg-primary/90 text-white font-semibold py-2.5 px-6 rounded-lg transition-colors">
                Save Changes
            </button>
            <a asp-action="Users"
                class="inline-flex items-center justify-center py-2.5 px-6 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-700 dark:text-slate-300 font-medium hover:bg-slate-50 dark:hover:bg-slate-800">
                Cancel
            </a>
        </div>
        <div></div>
        <label asp-for="DisplayName" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Display
            Name (Optional)</label>
        <input asp-for="DisplayName"
            class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent"
            placeholder="e.g. John Doe" />
        <span asp-validation-for="DisplayName" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="NewPassword"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <input asp-for="NewPassword" type="password"
                class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent"
                placeholder="Leave blank to keep current password" />
            <span asp-validation-for="NewPassword" class="text-red-500 text-sm"></span>
            <p class="text-xs text-slate-500 mt-1">Only fill this out if you want to force a password change.</p>
        </div>
        <div>
            <label asp-for="Role" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
    </form>
</main>