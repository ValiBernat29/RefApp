@model IEnumerable<RefApp.Models.Match>
@{
    ViewData["Title"] = "Upcoming Matches";
}

<main class="page">
    <h1 class="section-title">Upcoming Matches</h1>
    <div class="toolbar">
        <div></div>
        <a asp-action="CreateMatch" class="btn btn-primary">Add New Match</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    <div class="panel">
        <div class="panel-body">
        <form method="get" asp-action="UpcomingMatches" class="form-grid">

            <div class="flex-1 w-full">
                <label for="league">League</label>
                <select id="league" name="league">
                    <option value="">-- All Leagues --</option>
                    @foreach (var l in Enum.GetValues<RefApp.Models.League>())
                    {
                        if (ViewBag.SelectedLeague == l.ToString())
                        {
                            <option value="@l" selected>@l</option>
                        }
                        else
                        {
                            <option value="@l">@l</option>
                        }
                    }
                </select>
            </div>

            <div class="flex-1 w-full">
                <label for="startDate">From Date</label>
                <input type="date" id="startDate" name="startDate" value="@ViewBag.StartDate" />
            </div>

            <div class="flex-1 w-full">
                <label for="endDate">To Date</label>
                <input type="date" id="endDate" name="endDate" value="@ViewBag.EndDate" />
            </div>

            <div class="actions">
                <button type="submit" class="btn btn-primary">Filter</button>
                <a asp-action="UpcomingMatches" class="btn btn-secondary">Clear</a>
            </div>
        </form>
        </div>
    </div>
    <div class="panel">
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Match</th>
                        <th>Location</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="4">
                                No matches found for the selected filters.
                            </td>
                        </tr>
                    }
                    @foreach (var m in Model)
                    {
                        <tr>
                            <td>@m.MatchDate.ToString("dd MMM yyyy HH:mm")</td>
                            <td>
                                <span>@m.HomeTeam</span> vs <span>@m.AwayTeam</span>
                            </td>
                            <td>@m.Location</td>
                            <td class="actions">
                                <a asp-action="Assign" asp-route-id="@m.Id" class="btn btn-sm btn-primary">Assign Refs</a>
                                <a asp-action="EditMatch" asp-route-id="@m.Id" class="btn btn-sm btn-secondary">Edit</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</main>