@model IEnumerable<RefApp.Models.Match>
@{
    ViewData["Title"] = "Upcoming Matches";
}

<main class="flex-1 p-4 pb-24">
    <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4 mb-6">
        <h1 class="text-2xl font-bold tracking-tight">Upcoming Matches</h1>
        <a asp-action="CreateMatch" class="inline-flex items-center justify-center gap-2 bg-primary hover:bg-primary/90 text-white font-semibold py-2.5 px-4 rounded-lg transition-colors">
            <span class="material-symbols-outlined text-lg">add</span>
            Create Match
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="mb-4 p-4 rounded-lg bg-green-100 dark:bg-green-900/30 text-green-800 dark:text-green-200 border border-green-200 dark:border-green-800">
            @TempData["Success"]
        </div>
    }

    <div class="bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl overflow-hidden shadow-sm">
        @if (!Model.Any())
        {
            <div class="p-8 text-center text-slate-500 dark:text-slate-400">
                <span class="material-symbols-outlined text-4xl mb-2 block">sports_soccer</span>
                <p>No upcoming matches. <a asp-action="CreateMatch" class="text-primary dark:text-slate-300 font-medium hover:underline">Create one</a>.</p>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead class="bg-slate-50 dark:bg-slate-800/50 border-b border-slate-200 dark:border-slate-700">
                        <tr>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Date</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Match</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Location</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Referees</th>
                            <th class="px-4 py-3 text-xs font-semibold text-slate-500 dark:text-slate-400 uppercase tracking-wider">Actions</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-200 dark:divide-slate-700">
                        @foreach (var m in Model)
                        {
                            var main = m.Assignments.FirstOrDefault(a => a.RoleType == RefApp.Models.MatchRoleType.Main)?.Referee?.DisplayName ?? m.Assignments.FirstOrDefault(a => a.RoleType == RefApp.Models.MatchRoleType.Main)?.Referee?.Email ?? "—";
                            var a1 = m.Assignments.FirstOrDefault(a => a.RoleType == RefApp.Models.MatchRoleType.Assistant1)?.Referee?.DisplayName ?? m.Assignments.FirstOrDefault(a => a.RoleType == RefApp.Models.MatchRoleType.Assistant1)?.Referee?.Email ?? "—";
                            var a2 = m.Assignments.FirstOrDefault(a => a.RoleType == RefApp.Models.MatchRoleType.Assistant2)?.Referee?.DisplayName ?? m.Assignments.FirstOrDefault(a => a.RoleType == RefApp.Models.MatchRoleType.Assistant2)?.Referee?.Email ?? "—";
                            <tr class="hover:bg-slate-50 dark:hover:bg-slate-800/30">
                                <td class="px-4 py-3 text-sm">@m.MatchDate.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="px-4 py-3 font-medium">@m.HomeTeam vs @m.AwayTeam</td>
                                <td class="px-4 py-3 text-sm text-slate-600 dark:text-slate-400">@m.Location</td>
                                <td class="px-4 py-3 text-sm text-slate-600 dark:text-slate-400">
                                    <span class="block">Main: @main</span>
                                    <span class="block">Asst 1: @a1</span>
                                    <span class="block">Asst 2: @a2</span>
                                </td>
                                <td class="px-4 py-3 space-x-3">
                                    <a asp-action="Assign" asp-route-id="@m.Id" class="inline-flex items-center gap-1 text-primary dark:text-slate-300 font-medium hover:underline text-sm">
                                        <span class="material-symbols-outlined text-base">person_add</span>
                                        Assign
                                    </a>
                                    <a asp-action="EditMatch" asp-route-id="@m.Id" class="inline-flex items-center gap-1 text-slate-600 dark:text-slate-300 font-medium hover:underline text-sm">
                                        <span class="material-symbols-outlined text-base">edit_calendar</span>
                                        Edit
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</main>
