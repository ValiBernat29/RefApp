@model IEnumerable<RefApp.Models.Match>
@{
    ViewData["Title"] = "Upcoming Matches";
}

<main class="max-w-[1440px] mx-auto p-8 space-y-6">

    <!-- Page Header -->
    <div class="flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-bold text-gray-900">Upcoming Matches</h1>
            <nav class="text-sm text-gray-400 mt-0.5">
                <a asp-controller="Board" asp-action="Index" class="hover:text-gray-600">Dashboard</a>
                <span class="mx-1">•</span><span>Matches</span>
            </nav>
        </div>
        <a asp-action="CreateMatch"
           class="btn-assign text-white px-5 py-2.5 rounded-lg text-sm font-medium inline-flex items-center space-x-2">
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path d="M12 6v6m0 0v6m0-6h6m-6 0H6" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"/>
            </svg>
            <span>Add New Match</span>
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }

    <!-- Filter Panel -->
    <section class="bg-white rounded-xl card-shadow p-6">
        <form method="get" asp-action="UpcomingMatches" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 items-end">
            <div class="space-y-1.5">
                <label for="league" class="block text-sm font-medium text-gray-600">League</label>
                <select id="league" name="league"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400">
                    <option value="">-- All Leagues --</option>
                    @foreach (var l in Enum.GetValues<RefApp.Models.League>())
                    {
                        if (ViewBag.SelectedLeague == l.ToString())
                        {
                            <option value="@l" selected>@l</option>
                        }
                        else
                        {
                            <option value="@l">@l</option>
                        }
                    }
                </select>
            </div>
            <div class="space-y-1.5">
                <label for="startDate" class="block text-sm font-medium text-gray-600">From Date</label>
                <input type="date" id="startDate" name="startDate" value="@ViewBag.StartDate"
                       class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
            </div>
            <div class="space-y-1.5">
                <label for="endDate" class="block text-sm font-medium text-gray-600">To Date</label>
                <input type="date" id="endDate" name="endDate" value="@ViewBag.EndDate"
                       class="w-full border border-gray-200 rounded-lg px-3 py-2 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
            </div>
            <div class="flex items-end gap-2">
                <button type="submit"
                        class="btn-assign text-white px-5 py-2.5 rounded-lg text-sm font-medium flex-1">Filter</button>
                <a asp-action="UpcomingMatches"
                   class="action-btn-outline px-5 py-2.5 rounded-lg text-sm font-medium">Clear</a>
            </div>
        </form>
    </section>

    <!-- Matches Table -->
    <section class="bg-white rounded-xl card-shadow overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-left">
                <thead>
                    <tr class="bg-gray-50 text-gray-500 text-xs font-medium uppercase tracking-wider">
                        <th class="px-6 py-3">Date</th>
                        <th class="px-6 py-3">Match</th>
                        <th class="px-6 py-3">Location</th>
                        <th class="px-6 py-3">Referees</th>
                        <th class="px-6 py-3">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="px-6 py-10 text-center text-gray-400 text-sm">
                                No matches found for the selected filters.
                            </td>
                        </tr>
                    }
                    @foreach (var m in Model)
                    {
                        var mainRef   = m.Assignments.FirstOrDefault(a => a.RoleType == RefApp.Models.MatchRoleType.Main);
                        var asst1Ref  = m.Assignments.FirstOrDefault(a => a.RoleType == RefApp.Models.MatchRoleType.Assistant1);
                        var asst2Ref  = m.Assignments.FirstOrDefault(a => a.RoleType == RefApp.Models.MatchRoleType.Assistant2);
                        var assigned  = m.Assignments.Count;
                        string statusCss, statusLabel;
                        if (assigned >= 3)      { statusCss = "bg-emerald-50 text-emerald-700 border border-emerald-200"; statusLabel = "✓ Full"; }
                        else if (assigned > 0)  { statusCss = "bg-amber-50 text-amber-700 border border-amber-200";   statusLabel = "⚠ Partial"; }
                        else                    { statusCss = "bg-red-50 text-red-500 border border-red-200";           statusLabel = "✗ None"; }
                        <tr class="text-gray-700 hover:bg-gray-50/50 transition-colors">
                            <td class="px-6 py-4 text-sm">@m.MatchDate.ToString("dd MMM yyyy HH:mm")</td>
                            <td class="px-6 py-4 font-medium">@m.HomeTeam?.Name vs @m.AwayTeam?.Name</td>
                            <td class="px-6 py-4 text-sm">@m.Location</td>
                            <td class="px-6 py-4">
                                <div class="flex flex-col gap-1.5">
                                    <span class="inline-flex items-center gap-1.5 text-xs font-semibold px-2 py-0.5 rounded-full w-fit @statusCss">@statusLabel</span>
                                    @if (mainRef != null)
                                    {
                                        var mainName = mainRef.Referee?.DisplayName ?? mainRef.Referee?.UserName ?? mainRef.Referee?.Email ?? "?";
                                        <span class="inline-flex items-center gap-1 text-xs text-gray-600">
                                            <span class="font-semibold text-sky-600 w-6">M</span>@mainName
                                        </span>
                                    }
                                    @if (asst1Ref != null)
                                    {
                                        var a1Name = asst1Ref.Referee?.DisplayName ?? asst1Ref.Referee?.UserName ?? asst1Ref.Referee?.Email ?? "?";
                                        <span class="inline-flex items-center gap-1 text-xs text-gray-600">
                                            <span class="font-semibold text-indigo-500 w-6">A1</span>@a1Name
                                        </span>
                                    }
                                    @if (asst2Ref != null)
                                    {
                                        var a2Name = asst2Ref.Referee?.DisplayName ?? asst2Ref.Referee?.UserName ?? asst2Ref.Referee?.Email ?? "?";
                                        <span class="inline-flex items-center gap-1 text-xs text-gray-600">
                                            <span class="font-semibold text-indigo-500 w-6">A2</span>@a2Name
                                        </span>
                                    }
                                </div>
                            </td>
                            <td class="px-6 py-4">
                                <div class="flex items-center gap-2">
                                    <a asp-action="Assign" asp-route-id="@m.Id"
                                       class="btn-assign text-white px-4 py-1.5 rounded-lg text-sm font-medium">Assign Refs</a>
                                    <a asp-action="EditMatch" asp-route-id="@m.Id"
                                       class="action-btn-outline px-4 py-1.5 rounded-lg text-sm font-medium">Edit</a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </section>

</main>