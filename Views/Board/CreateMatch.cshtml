@model RefApp.ViewModels.CreateMatchViewModel
@{
    ViewData["Title"] = "Create Match";
}

<main class="max-w-[1440px] mx-auto p-8 space-y-6">

    <div>
        <h1 class="text-2xl font-bold text-gray-900">Create Match</h1>
        <nav class="text-sm text-gray-400 mt-0.5">
            <a asp-controller="Board" asp-action="Index" class="hover:text-gray-600">Dashboard</a>
            <span class="mx-1">•</span>
            <a asp-controller="Board" asp-action="UpcomingMatches" class="hover:text-gray-600">Matches</a>
            <span class="mx-1">•</span><span>Create</span>
        </nav>
    </div>

    <section class="bg-white rounded-xl card-shadow p-6 max-w-xl">
        <form asp-action="CreateMatch" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="validation"></div>

            <div class="space-y-1.5">
                <label asp-for="League" class="block text-sm font-medium text-gray-700"></label>
                <select asp-for="League" asp-items="Html.GetEnumSelectList<RefApp.Models.League>()" id="leagueSelect"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400">
                    <option value="">Select league</option>
                </select>
                <span asp-validation-for="League" class="validation"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="MatchDate" class="block text-sm font-medium text-gray-700"></label>
                <input asp-for="MatchDate" type="datetime-local" step="3600"
                       class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                <span asp-validation-for="MatchDate" class="validation"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Location" class="block text-sm font-medium text-gray-700"></label>
                <input asp-for="Location" placeholder="e.g. Riverside Stadium"
                       class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                <span asp-validation-for="Location" class="validation"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="HomeTeamId" class="block text-sm font-medium text-gray-700"></label>
                <select asp-for="HomeTeamId"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400">
                    <option value="">Select home team</option>
                    @if (Model.Teams != null)
                    {
                        foreach (var t in Model.Teams.OrderBy(t => t.Name))
                        {
                            <option value="@t.Id" data-league="@((int)t.League)">@t.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="HomeTeamId" class="validation"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="AwayTeamId" class="block text-sm font-medium text-gray-700"></label>
                <select asp-for="AwayTeamId"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400">
                    <option value="">Select away team</option>
                    @if (Model.Teams != null)
                    {
                        foreach (var t in Model.Teams.OrderBy(t => t.Name))
                        {
                            <option value="@t.Id" data-league="@((int)t.League)">@t.Name</option>
                        }
                    }
                </select>
                <span asp-validation-for="AwayTeamId" class="validation"></span>
            </div>

            <div class="flex items-center gap-3 pt-2">
                <button type="submit"
                        class="btn-assign text-white px-6 py-2.5 rounded-lg text-sm font-medium">Create Match</button>
                <a asp-action="UpcomingMatches"
                   class="action-btn-outline px-6 py-2.5 rounded-lg text-sm font-medium">Cancel</a>
            </div>
        </form>
    </section>

</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const leagueSelect = document.getElementById('leagueSelect');
            const homeSelect = document.getElementById('@Html.IdFor(m => m.HomeTeamId)');
            const awaySelect = document.getElementById('@Html.IdFor(m => m.AwayTeamId)');
            const matchDateInput = document.getElementById('@Html.IdFor(m => m.MatchDate)');

            function toLocalDateTimeValue(d) {
                const pad = (n) => String(n).padStart(2, '0');
                return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
            }

            function snapToHour() {
                if (!matchDateInput) return;
                const raw = matchDateInput.value;
                if (!raw) return;
                const d = new Date(raw);
                if (Number.isNaN(d.getTime())) return;
                d.setMinutes(0, 0, 0);
                matchDateInput.value = toLocalDateTimeValue(d);
            }

            function filterTeams() {
                const league = leagueSelect.value;
                [homeSelect, awaySelect].forEach(select => {
                    if (!select) return;
                    Array.from(select.options).forEach(opt => {
                        if (!opt.value) return;
                        const optLeague = opt.getAttribute('data-league');
                        opt.hidden = league && optLeague !== league;
                    });
                });
            }

            if (leagueSelect) {
                leagueSelect.addEventListener('change', filterTeams);
                filterTeams();
            }

            if (matchDateInput) {
                if (!matchDateInput.value) {
                    const d = new Date();
                    d.setHours(d.getHours() + 1);
                    d.setMinutes(0, 0, 0);
                    matchDateInput.value = toLocalDateTimeValue(d);
                } else {
                    snapToHour();
                }
                matchDateInput.addEventListener('change', snapToHour);
                matchDateInput.addEventListener('blur', snapToHour);
            }
        })();
    </script>
}
