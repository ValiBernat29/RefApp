@model RefApp.ViewModels.CreateMatchViewModel
@{
    ViewData["Title"] = "Create Match";
}

<main class="page">
    <h1 class="section-title">Create Match</h1>
    <form asp-action="CreateMatch" method="post" class="form-card form-grid">
        <div asp-validation-summary="ModelOnly" class="validation"></div>

        <div>
            <label asp-for="League"></label>
            <select asp-for="League"
                    asp-items="Html.GetEnumSelectList<RefApp.Models.League>()"
                    id="leagueSelect">
                <option value="">Select league</option>
            </select>
            <span asp-validation-for="League" class="validation"></span>
        </div>

        <div>
            <label asp-for="MatchDate"></label>
            <input asp-for="MatchDate" type="datetime-local" step="3600" />
            <span asp-validation-for="MatchDate" class="validation"></span>
        </div>

        <div>
            <label asp-for="Location"></label>
            <input asp-for="Location" placeholder="e.g. Riverside Stadium" />
            <span asp-validation-for="Location" class="validation"></span>
        </div>

        <div>
            <label asp-for="HomeTeamId"></label>
            <select asp-for="HomeTeamId">
                <option value="">Select home team</option>
                @if (Model.Teams != null)
                {
                    foreach (var t in Model.Teams.OrderBy(t => t.Name))
                    {
                        <option value="@t.Id" data-league="@((int)t.League)">@t.Name</option>
                    }
                }
            </select>
            <span asp-validation-for="HomeTeamId" class="validation"></span>
        </div>

        <div>
            <label asp-for="AwayTeamId"></label>
            <select asp-for="AwayTeamId">
                <option value="">Select away team</option>
                @if (Model.Teams != null)
                {
                    foreach (var t in Model.Teams.OrderBy(t => t.Name))
                    {
                        <option value="@t.Id" data-league="@((int)t.League)">@t.Name</option>
                    }
                }
            </select>
            <span asp-validation-for="AwayTeamId" class="validation"></span>
        </div>

        <div class="actions">
            <button type="submit" class="btn btn-primary">Create Match</button>
            <a asp-action="UpcomingMatches" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const leagueSelect = document.getElementById('leagueSelect');
            const homeSelect = document.getElementById('@Html.IdFor(m => m.HomeTeamId)');
            const awaySelect = document.getElementById('@Html.IdFor(m => m.AwayTeamId)');
            const matchDateInput = document.getElementById('@Html.IdFor(m => m.MatchDate)');

            function toLocalDateTimeValue(d) {
                const pad = (n) => String(n).padStart(2, '0');
                return `${d.getFullYear()}-${pad(d.getMonth() + 1)}-${pad(d.getDate())}T${pad(d.getHours())}:${pad(d.getMinutes())}`;
            }

            function snapToHour() {
                if (!matchDateInput) return;
                const raw = matchDateInput.value;
                if (!raw) return;
                const d = new Date(raw);
                if (Number.isNaN(d.getTime())) return;
                d.setMinutes(0, 0, 0);
                matchDateInput.value = toLocalDateTimeValue(d);
            }

            function filterTeams() {
                const league = leagueSelect.value;
                [homeSelect, awaySelect].forEach(select => {
                    if (!select) return;
                    Array.from(select.options).forEach(opt => {
                        if (!opt.value) return; // keep placeholder
                        const optLeague = opt.getAttribute('data-league');
                        opt.hidden = league && optLeague !== league;
                    });
                });
            }

            if (leagueSelect) {
                leagueSelect.addEventListener('change', filterTeams);
                filterTeams();
            }

            if (matchDateInput) {
                // Default to next full hour if empty.
                if (!matchDateInput.value) {
                    const d = new Date();
                    d.setHours(d.getHours() + 1);
                    d.setMinutes(0, 0, 0);
                    matchDateInput.value = toLocalDateTimeValue(d);
                } else {
                    snapToHour();
                }

                matchDateInput.addEventListener('change', snapToHour);
                matchDateInput.addEventListener('blur', snapToHour);
            }
        })();
    </script>
}
