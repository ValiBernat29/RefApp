@model RefApp.Models.Match
@{
    ViewData["Title"] = "Create Match";
}

<main class="flex-1 p-4 pb-24 max-w-2xl mx-auto">
    <h1 class="text-2xl font-bold tracking-tight mb-6">Create Match</h1>

    <form asp-action="CreateMatch" method="post" class="space-y-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm">
        <div asp-validation-summary="ModelOnly" class="text-red-600 dark:text-red-400 text-sm"></div>

        <div>
            <label asp-for="MatchDate" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <input asp-for="MatchDate" type="datetime-local" class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent" />
            <span asp-validation-for="MatchDate" class="text-red-600 dark:text-red-400 text-xs"></span>
        </div>

        <div>
            <label asp-for="Location" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <input asp-for="Location" class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="e.g. Riverside Stadium" />
            <span asp-validation-for="Location" class="text-red-600 dark:text-red-400 text-xs"></span>
        </div>

        <div>
            <label asp-for="HomeTeam" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <input asp-for="HomeTeam" class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Home team name" />
            <span asp-validation-for="HomeTeam" class="text-red-600 dark:text-red-400 text-xs"></span>
        </div>

        <div>
            <label asp-for="AwayTeam" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1"></label>
            <input asp-for="AwayTeam" class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent" placeholder="Away team name" />
            <span asp-validation-for="AwayTeam" class="text-red-600 dark:text-red-400 text-xs"></span>
        </div>

        <div class="flex gap-3 pt-2">
            <button type="submit" class="bg-primary hover:bg-primary/90 text-white font-semibold py-2.5 px-6 rounded-lg transition-colors">
                Create Match
            </button>
            <a asp-action="UpcomingMatches" class="inline-flex items-center justify-center py-2.5 px-6 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-700 dark:text-slate-300 font-medium hover:bg-slate-50 dark:hover:bg-slate-800">
                Cancel
            </a>
        </div>
    </form>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
