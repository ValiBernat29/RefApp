@model IEnumerable<RefApp.Models.ApplicationUser>
@{
    ViewData["Title"] = "User Management";
    var roles = ViewBag.UserRoles as Dictionary<string, string>;
}

<main class="page">
    <h1 class="section-title">System Users</h1>
    <div class="toolbar"><div></div><a asp-area="Identity" asp-page="/Account/Register" class="btn btn-primary">Add New User</a></div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">@TempData["Success"]</div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-error">@TempData["Error"]</div>
    }

    <div class="panel">
        <div class="table-wrap">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Username</th>
                        <th>Display Name</th>
                        <th>Role</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in Model)
                    {
                        var roleName = roles != null && roles.ContainsKey(u.Id) ? roles[u.Id] : "—";
                        <tr>
                            <td>@u.UserName</td>
                            <td>@(u.DisplayName ?? "—")</td>
                            <td>
                                <span class="badge @(roleName.Contains("Board") ? "b-amber" : "b-sky")">@roleName</span>
                            </td>
                            <td class="actions">
                                <a asp-action="EditUser" asp-route-id="@u.Id" class="btn btn-sm btn-secondary">Edit</a>

                                <form asp-action="DeleteUser" asp-route-id="@u.Id" method="post" class="inline"
                                    onsubmit="return confirm('Are you sure you want to permanently delete @u.UserName?');">
                                    <button type="submit" class="btn btn-sm btn-danger">Delete</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</main>