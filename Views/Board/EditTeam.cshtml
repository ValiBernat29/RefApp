@model RefApp.Models.Team
@{
    ViewData["Title"] = "Edit Team";
}

<main class="flex-1 p-4 pb-24 max-w-xl mx-auto">
    <h1 class="text-2xl font-bold tracking-tight mb-6">Edit Team</h1>

    <form asp-action="EditTeam" method="post"
        class="space-y-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="All" class="text-red-600 dark:text-red-400 text-sm"></div>

        <div>
            <label asp-for="Name" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Team
                Name</label>
            <input asp-for="Name"
                class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent" />
            <span asp-validation-for="Name" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="League" class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">League</label>
            <select asp-for="League" asp-items="Html.GetEnumSelectList<RefApp.Models.League>()" class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent"></select>
            <span asp-validation-for="League" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="PreferredMatchDay"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Preferred Match Day</label>
            <select asp-for="PreferredMatchDay" asp-items="Html.GetEnumSelectList<DayOfWeek>()"
                class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent"></select>
            <span asp-validation-for="PreferredMatchDay" class="text-red-500 text-sm"></span>
        </div>

        <div class="flex gap-3 pt-4">
            <button type="submit"
                class="bg-primary hover:bg-primary/90 text-white font-semibold py-2.5 px-6 rounded-lg transition-colors">
                Save Changes
            </button>
            <a asp-action="Teams"
                class="inline-flex items-center justify-center py-2.5 px-6 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-700 dark:text-slate-300 font-medium hover:bg-slate-50 dark:hover:bg-slate-800">
                Cancel
            </a>
        </div>
    </form>
</main>