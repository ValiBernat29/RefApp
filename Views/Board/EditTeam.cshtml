@model RefApp.Models.Team
@{
    ViewData["Title"] = "Edit Team";
}

<main class="page">
    <h1 class="section-title">Edit Team</h1>
    <form asp-action="EditTeam" method="post" class="form-card form-grid">
        <input type="hidden" asp-for="Id" />
        <div asp-validation-summary="All" class="validation"></div>

        <div>
            <label asp-for="Name">Team Name</label>
            <input asp-for="Name" />
            <span asp-validation-for="Name" class="validation"></span>
        </div>

        <div>
            <label asp-for="League">League</label>
            <select asp-for="League" asp-items="Html.GetEnumSelectList<RefApp.Models.League>()"></select>
            <span asp-validation-for="League" class="validation"></span>
        </div>

        <div>
            <label asp-for="PreferredMatchDay">Preferred Match Day</label>
            <select asp-for="PreferredMatchDay" asp-items="Html.GetEnumSelectList<DayOfWeek>()"></select>
            <span asp-validation-for="PreferredMatchDay" class="validation"></span>
        </div>

        <div class="actions">
            <button type="submit" class="btn btn-primary">Save Changes</button>
            <a asp-action="Teams" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</main>