@model RefApp.Models.Team
@{
    ViewData["Title"] = "Edit Team";
}

<main class="max-w-[1440px] mx-auto p-8 space-y-6">

    <div>
        <h1 class="text-2xl font-bold text-gray-900">Edit Team</h1>
        <nav class="text-sm text-gray-400 mt-0.5">
            <a asp-controller="Board" asp-action="Index" class="hover:text-gray-600">Dashboard</a>
            <span class="mx-1">•</span>
            <a asp-controller="Board" asp-action="Teams" class="hover:text-gray-600">Teams</a>
            <span class="mx-1">•</span><span>Edit</span>
        </nav>
    </div>

    <section class="bg-white rounded-xl card-shadow p-6 max-w-xl">
        <form asp-action="EditTeam" method="post" class="space-y-5">
            <input type="hidden" asp-for="Id" />
            <div asp-validation-summary="All" class="validation"></div>

            <div class="space-y-1.5">
                <label asp-for="Name" class="block text-sm font-medium text-gray-700">Team Name</label>
                <input asp-for="Name"
                       class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                <span asp-validation-for="Name" class="validation"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="League" class="block text-sm font-medium text-gray-700">League</label>
                <select asp-for="League" asp-items="Html.GetEnumSelectList<RefApp.Models.League>()"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400"></select>
                <span asp-validation-for="League" class="validation"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="PreferredMatchDay" class="block text-sm font-medium text-gray-700">Preferred Match Day</label>
                <select asp-for="PreferredMatchDay" asp-items="Html.GetEnumSelectList<DayOfWeek>()"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400"></select>
                <span asp-validation-for="PreferredMatchDay" class="validation"></span>
            </div>

            <div class="flex items-center gap-3 pt-2">
                <button type="submit"
                        class="btn-assign text-white px-6 py-2.5 rounded-lg text-sm font-medium">Save Changes</button>
                <a asp-action="Teams"
                   class="action-btn-outline px-6 py-2.5 rounded-lg text-sm font-medium">Cancel</a>
            </div>
        </form>
    </section>

</main>