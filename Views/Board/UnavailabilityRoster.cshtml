@model IEnumerable<RefApp.Models.Unavailability>
@{
    ViewData["Title"] = "Unavailability Roster";
}

<main class="page">
    <h1 class="section-title">Unavailability Roster</h1>

    <div class="panel">
        @if (!Model.Any())
        {
            <div class="panel-body"><p class="muted">No unavailability records.</p></div>
        }
        else
        {
            <div class="table-wrap">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Referee</th>
                            <th>Start Date</th>
                            <th>End Date</th>
                            <th>Reason</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var u in Model)
                        {
                            var name = u.Referee?.UserName ?? u.Referee?.Email ?? u.RefereeId;
                            <tr>
                                <td>@name</td>
                                <td>@u.StartDate.ToString("yyyy-MM-dd")</td>
                                <td>@u.EndDate.ToString("yyyy-MM-dd")</td>
                                <td>@(u.Reason ?? "—")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</main>
