@page
@model RegisterModel
@{
    ViewData["Title"] = "Register New Account";
}

<main class="flex-1 p-4 pb-24 max-w-md mx-auto w-full mt-8">
    <h1 class="text-2xl font-bold tracking-tight text-center mb-6">@ViewData["Title"]</h1>

    <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post"
        class="space-y-4 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-xl p-6 shadow-sm">
        <p class="text-slate-600 dark:text-slate-400 text-center mb-4">Create a new user account.</p>

        <div asp-validation-summary="ModelOnly" class="text-red-600 dark:text-red-400 text-sm" role="alert"></div>

        <div>
            <label asp-for="Input.Username"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Username</label>
            <input asp-for="Input.Username"
                class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent"
                autocomplete="username" aria-required="true" placeholder="Enter username" />
            <span asp-validation-for="Input.Username" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.Password"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Password</label>
            <input asp-for="Input.Password"
                class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent"
                autocomplete="new-password" aria-required="true" placeholder="Create a password" />
            <span asp-validation-for="Input.Password" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.ConfirmPassword"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Confirm Password</label>
            <input asp-for="Input.ConfirmPassword"
                class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent"
                autocomplete="new-password" aria-required="true" placeholder="Confirm your password" />
            <span asp-validation-for="Input.ConfirmPassword" class="text-red-500 text-sm"></span>
        </div>

        <div>
            <label asp-for="Input.Role"
                class="block text-sm font-medium text-slate-700 dark:text-slate-300 mb-1">Role</label>
            <select asp-for="Input.Role"
                class="w-full px-3 py-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent"
                aria-required="true">
                <option value="">Select role</option>
                <option value="Board">Board (Admin)</option>
                <option value="Referee">Referee</option>
            </select>
            <span asp-validation-for="Input.Role" class="text-red-500 text-sm"></span>
        </div>

        <div class="pt-2 pb-2">
            <button id="registerSubmit" type="submit"
                class="w-full bg-primary hover:bg-primary/90 text-white font-semibold py-2.5 rounded-lg transition-colors">
                Register Account
            </button>
        </div>
    </form>
</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}