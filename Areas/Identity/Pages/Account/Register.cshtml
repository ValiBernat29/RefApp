@page
@model RegisterModel
@{
    ViewData["Title"] = "Register New Account";
}

<main class="max-w-[1440px] mx-auto p-8 space-y-6">

    <div>
        <h1 class="text-2xl font-bold text-gray-900">Register New Account</h1>
        <nav class="text-sm text-gray-400 mt-0.5">
            <span>Admin</span>
            <span class="mx-1">•</span>
            <span>Create User</span>
        </nav>
    </div>

    <section class="bg-white rounded-xl card-shadow p-6 max-w-md">
        <p class="text-sm text-gray-500 mb-6">Create a new user account and assign them a role.</p>

        <form id="registerForm" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="space-y-5">
            <div asp-validation-summary="ModelOnly" class="validation" role="alert"></div>

            <div class="space-y-1.5">
                <label asp-for="Input.Username" class="block text-sm font-medium text-gray-700">Username</label>
                <input asp-for="Input.Username"
                       autocomplete="username" aria-required="true" placeholder="Enter username"
                       class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                <span asp-validation-for="Input.Username" class="validation"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Input.Password" class="block text-sm font-medium text-gray-700">Password</label>
                <input asp-for="Input.Password" type="password"
                       autocomplete="new-password" aria-required="true" placeholder="Create a password"
                       class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                <span asp-validation-for="Input.Password" class="validation"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-gray-700">Confirm Password</label>
                <input asp-for="Input.ConfirmPassword" type="password"
                       autocomplete="new-password" aria-required="true" placeholder="Confirm your password"
                       class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                <span asp-validation-for="Input.ConfirmPassword" class="validation"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Input.Role" class="block text-sm font-medium text-gray-700">Role</label>
                <select asp-for="Input.Role" aria-required="true"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400">
                    <option value="">Select role</option>
                    <option value="Board">Board (Admin)</option>
                    <option value="Referee">Referee</option>
                </select>
                <span asp-validation-for="Input.Role" class="validation"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Input.HomeCity" class="block text-sm font-medium text-gray-700">Home City / Village</label>
                <input asp-for="Input.HomeCity"
                       list="arad-localities"
                       placeholder="Type to search..."
                       autocomplete="off"
                       class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                <partial name="_CityDatalist" />
                <span asp-validation-for="Input.HomeCity" class="validation"></span>
            </div>

            <div class="space-y-1.5">
                <label asp-for="Input.Rank" class="block text-sm font-medium text-gray-700">Referee Tier (internal)</label>
                <select asp-for="Input.Rank" asp-items="Html.GetEnumSelectList<RefApp.Models.RefereeRank>()"
                        class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 bg-white focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400"></select>
                <span asp-validation-for="Input.Rank" class="validation"></span>
            </div>

            <div class="pt-2">
                <button id="registerSubmit" type="submit"
                        class="btn-assign w-full text-white font-semibold py-2.5 rounded-lg">
                    Register Account
                </button>
            </div>
        </form>
    </section>

</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}