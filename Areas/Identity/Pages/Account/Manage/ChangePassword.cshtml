@page
@model ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<main class="max-w-[1440px] mx-auto p-8 space-y-6">

    <div>
        <h1 class="text-2xl font-bold text-gray-900">My Account</h1>
        <nav class="text-sm text-gray-400 mt-0.5">
            <span>Account</span>
            <span class="mx-1">•</span>
            <span>Change Password</span>
        </nav>
    </div>

    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="@(Model.StatusMessage.StartsWith("Error") ? "alert alert-error" : "alert alert-success")">
            @Model.StatusMessage
        </div>
    }

    <div class="grid grid-cols-12 gap-8">

        <!-- Sidebar nav -->
        <aside class="col-span-12 lg:col-span-3">
            <div class="bg-white rounded-xl card-shadow p-4">
                <p class="text-xs font-semibold text-gray-400 uppercase tracking-wider px-4 mb-3">Settings</p>
                <partial name="_ManageNav" />
            </div>
        </aside>

        <!-- Main content -->
        <div class="col-span-12 lg:col-span-9">
            <section class="bg-white rounded-xl card-shadow p-6 max-w-xl">
                <h2 class="text-lg font-semibold text-gray-800 mb-5">Change Password</h2>

                <form id="change-password-form" method="post" class="space-y-5">
                    <div asp-validation-summary="ModelOnly" class="validation" role="alert"></div>

                    <div class="space-y-1.5">
                        <label asp-for="Input.OldPassword" class="block text-sm font-medium text-gray-700">Current Password</label>
                        <input asp-for="Input.OldPassword" type="password"
                               autocomplete="current-password" aria-required="true"
                               placeholder="Enter your current password"
                               class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                        <span asp-validation-for="Input.OldPassword" class="validation"></span>
                    </div>

                    <div class="space-y-1.5">
                        <label asp-for="Input.NewPassword" class="block text-sm font-medium text-gray-700">New Password</label>
                        <input asp-for="Input.NewPassword" type="password"
                               autocomplete="new-password" aria-required="true"
                               placeholder="Enter your new password"
                               class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                        <span asp-validation-for="Input.NewPassword" class="validation"></span>
                    </div>

                    <div class="space-y-1.5">
                        <label asp-for="Input.ConfirmPassword" class="block text-sm font-medium text-gray-700">Confirm New Password</label>
                        <input asp-for="Input.ConfirmPassword" type="password"
                               autocomplete="new-password" aria-required="true"
                               placeholder="Confirm your new password"
                               class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                        <span asp-validation-for="Input.ConfirmPassword" class="validation"></span>
                    </div>

                    <div class="pt-1">
                        <button type="submit"
                                class="btn-assign text-white px-6 py-2.5 rounded-lg text-sm font-medium">
                            Update Password
                        </button>
                    </div>
                </form>
            </section>
        </div>

    </div>

</main>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
