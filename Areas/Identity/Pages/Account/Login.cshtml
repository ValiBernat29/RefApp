@page
@model LoginModel

@{
    ViewData["Title"] = "Log In";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Referee Portal | Log In</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <style>
        body { font-family: 'Inter', sans-serif; }
        .card-shadow { box-shadow: 0 4px 24px -4px rgba(0,0,0,0.06); }
        .btn-assign { background-color: #6eb7e4; transition: background-color 0.2s; }
        .btn-assign:hover { background-color: #5ca5d2; }
    </style>
</head>
<body class="bg-[#f4f7f9] text-slate-800 min-h-screen flex flex-col">

    <!-- Header -->
    <header class="bg-white px-8 py-4 flex items-center border-b border-gray-100">
        <div class="flex items-center space-x-2">
            <img src="~/images/RefappLogo.png" alt="RefApp Logo" class="h-16 w-auto object-contain" />
        </div>
    </header>

    <!-- Main -->
    <main class="flex-1 flex items-center justify-center p-8">
        <div class="w-full max-w-md space-y-6">

            <div class="text-center">
                <h1 class="text-2xl font-bold text-gray-900">Welcome back</h1>
                <p class="text-sm text-gray-400 mt-1">Sign in to your account to continue</p>
            </div>

            <section class="bg-white rounded-xl card-shadow p-6">
                <form id="account" method="post" class="space-y-5">
                    <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm font-medium" role="alert"></div>

                    <div class="space-y-1.5">
                        <label class="block text-sm font-medium text-gray-700">Username</label>
                        <input asp-for="Input.UserName" autocomplete="username" type="text"
                               placeholder="Enter your username"
                               class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                        <span asp-validation-for="Input.UserName" class="text-red-500 text-xs"></span>
                    </div>

                    <div class="space-y-1.5">
                        <label class="block text-sm font-medium text-gray-700">Password</label>
                        <input asp-for="Input.Password" autocomplete="current-password" type="password"
                               placeholder="••••••••"
                               class="w-full border border-gray-200 rounded-lg px-3 py-2.5 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-sky-300 focus:border-sky-400" />
                        <span asp-validation-for="Input.Password" class="text-red-500 text-xs"></span>
                    </div>

                    <div class="flex items-center">
                        <input asp-for="Input.RememberMe" id="remember"
                               class="w-4 h-4 text-sky-500 border-gray-300 rounded focus:ring-sky-400" />
                        <label class="ml-2 text-sm text-gray-500" asp-for="Input.RememberMe">Remember me for 30 days</label>
                    </div>

                    <div class="pt-1">
                        <button id="login-submit" type="submit"
                                class="btn-assign w-full text-white font-semibold py-2.5 rounded-lg">
                            Sign In
                        </button>
                    </div>
                </form>
            </section>

        </div>
    </main>

    <partial name="_ValidationScriptsPartial" />
</body>
</html>