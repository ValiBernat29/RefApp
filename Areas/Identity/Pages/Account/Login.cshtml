@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
    Layout = null; // This disables the default header/footer to keep your custom design pure!
}

<!DOCTYPE html>
<html class="dark" lang="en">

<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Referee Portal | Secure Login</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&display=swap"
        rel="stylesheet" />
    <script>
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        "primary": "#1a2b3d",
                        "accent-green": "#22c55e",
                        "background-light": "#f6f7f7",
                        "background-dark": "#15191d",
                    },
                    fontFamily: { "display": ["Inter", "sans-serif"] },
                    borderRadius: { "DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px" },
                },
            },
        }
    </script>
    <style>
        body {
            min-height: max(884px, 100dvh);
        }
    </style>
</head>

<body
    class="font-display bg-background-light dark:bg-background-dark text-slate-900 dark:text-slate-100 min-h-screen flex flex-col">
    <div class="relative flex min-h-screen w-full flex-col overflow-x-hidden">
        <main class="flex-1 flex flex-col lg:flex-row">
            <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-primary items-center justify-center p-12">
                <div class="absolute inset-0 opacity-40 bg-cover bg-center"
                    data-alt="Professional sports official whistle and timer on field"
                    style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBahyWu33_AZj3ICEaHBVBrX5OG38GOhB4OUxgcAveZKc4bdxoqp1GGUvEFMbXGTmFTjtM0UOFBJjgabxlBoB02KY0AinVSVN-Jrpb-qLM46zZmOcrR7tMGjxecuOlWv3_Pbpp7j_Z0pq-AFnnG-KNzggaot34YwL_va-e1o4U9UnBFHb61NK3XMEc8aA1Zxaeksvs1-PK3p6N8ml0xausewm5K69Ra5ClS5k7LRg7-6e0QYsIvbsWLpoMqn-qPhrjS1sK38Vm32cw');">
                </div>
                <div class="absolute inset-0 bg-gradient-to-br from-primary via-primary/80 to-transparent"></div>
                <div class="relative z-10 max-w-md">
                    <div class="bg-accent-green/20 p-3 rounded-xl inline-block mb-6">
                        <span class="material-symbols-outlined text-accent-green text-4xl">sports_score</span>
                    </div>
                    <h1 class="text-4xl font-bold text-white mb-4 leading-tight">Empowering Sports Officials Worldwide.
                    </h1>
                    <p class="text-slate-300 text-lg leading-relaxed">Access your assignments, review match footage, and
                        manage certifications in one secure location.</p>
                </div>
            </div>

            <div class="flex-1 flex items-center justify-center p-6 md:p-12">
                <div class="w-full max-w-md space-y-8">
                    <div class="lg:hidden flex flex-col items-center mb-8">
                        <div class="bg-primary p-3 rounded-full mb-4">
                            <span class="material-symbols-outlined text-white text-3xl">sports_and_outdoors</span>
                        </div>
                    </div>
                    <div class="text-center lg:text-left">
                        <h2 class="text-3xl font-bold text-slate-900 dark:text-white tracking-tight">Welcome Back</h2>
                        <p class="text-slate-500 dark:text-slate-400 mt-2">Please enter your credentials to access the
                            dashboard.</p>
                    </div>

                    <form id="account" method="post" class="space-y-6 mt-8">
                        <div asp-validation-summary="ModelOnly" class="text-red-500 font-semibold mb-4" role="alert">
                        </div>

                        <div class="space-y-4">
                            <label class="block">
                                <span
                                    class="text-sm font-semibold text-slate-700 dark:text-slate-300 mb-2 block">Username</span>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">person</span>
                                    <input asp-for="Input.UserName" autocomplete="username" type="text"
                                        class="w-full pl-11 pr-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-slate-400"
                                        placeholder="Enter your username" />
                                </div>
                                <span asp-validation-for="Input.UserName"
                                    class="text-red-500 text-sm mt-1 block"></span>
                            </label>

                            <label class="block">
                                <div class="flex justify-between items-center mb-2">
                                    <span
                                        class="text-sm font-semibold text-slate-700 dark:text-slate-300">Password</span>
                                    <a class="text-sm font-medium text-primary dark:text-slate-400 hover:underline"
                                        asp-page="./ForgotPassword">Forgot Password?</a>
                                </div>
                                <div class="relative">
                                    <span
                                        class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400">lock</span>
                                    <input asp-for="Input.Password" autocomplete="current-password" type="password"
                                        class="w-full pl-11 pr-4 py-3 bg-white dark:bg-slate-900 border border-slate-200 dark:border-slate-800 rounded-lg text-slate-900 dark:text-slate-100 focus:ring-2 focus:ring-primary focus:border-transparent outline-none transition-all placeholder:text-slate-400"
                                        placeholder="••••••••" />
                                </div>
                                <span asp-validation-for="Input.Password"
                                    class="text-red-500 text-sm mt-1 block"></span>
                            </label>
                        </div>

                        <div class="flex items-center">
                            <input asp-for="Input.RememberMe" id="remember"
                                class="w-4 h-4 text-primary bg-slate-100 border-slate-300 rounded focus:ring-primary dark:focus:ring-primary dark:ring-offset-slate-800 dark:bg-slate-700 dark:border-slate-600" />
                            <label class="ml-2 text-sm text-slate-600 dark:text-slate-400"
                                asp-for="Input.RememberMe">Remember this device for 30 days</label>
                        </div>

                        <button id="login-submit" type="submit"
                            class="w-full bg-accent-green hover:bg-green-600 text-white font-bold py-4 rounded-lg shadow-lg shadow-green-900/20 transition-all flex items-center justify-center gap-2">
                            <span>Sign In</span>
                            <span class="material-symbols-outlined">login</span>
                        </button>
                    </form>

                    <div class="pt-8 border-t border-slate-200 dark:border-slate-800 text-center">
                        <p class="text-sm text-slate-500 dark:text-slate-400">
                            New official? <a class="text-primary dark:text-slate-300 font-bold hover:underline"
                                href="#">Request Access</a>
                        </p>
                    </div>
                </div>
            </div>
        </main>
    </div>

    <partial name="_ValidationScriptsPartial" />
</body>

</html>